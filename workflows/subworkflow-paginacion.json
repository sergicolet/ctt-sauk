    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst result = [];\nfor (const item of items) {\n  const data = item.json.data;\n  if (!data || !Array.isArray(data)) continue;\n  for (const shipping of data) {\n    if (shipping && shipping.shipping_code) {\n      result.push({ json: shipping });\n    }\n  }\n}\nreturn result;"
      },
