    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst lastPage = item.pagination?.page_offsets?.last ?? 1;\nconst centerCode = item.data?.[0]?.client_center_code || '';\n\nconst pages = [];\nfor (let i = 2; i <= lastPage; i++) {\n  pages.push({ json: { page: i, center_code: centerCode } });\n}\nreturn pages;"
      },
