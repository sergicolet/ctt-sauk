        },
        {
            "parameters": {
                "jsCode": "// Código Robusto para el nodo \"Merge History1\"\nconst item = $('Switch').item.json;\nconst history = $json; \n\n// 1. Buscamos el array de eventos en todas las rutas posibles de CTT\nlet events = [];\nif (Array.isArray(history)) {\n    events = history;\n} else if (history.data && history.data.shipping_history && Array.isArray(history.data.shipping_history.events)) {\n    // Ruta detectada: data -> shipping_history -> events\n    events = history.data.shipping_history.events;\n} else if (history.data && Array.isArray(history.data)) {\n    events = history.data;\n} else if (history.events && Array.isArray(history.events)) {\n    events = history.events;\n} else if (history.shipping_history && Array.isArray(history.shipping_history)) {\n    events = history.shipping_history;\n}\n\n// 2. Buscamos el código 1600 de forma segura (usando field 'code')\nconst has1600 = events.some(event => event.code === \"1600\" || event.event_code === \"1600\" || event.status_code === \"1600\");\n\nreturn {\n  ...item,\n  status_history: events,\n  history_has_1600: has1600\n};"
            },
