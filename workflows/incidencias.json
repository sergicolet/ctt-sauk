    {
      "parameters": {
        "jsCode": "try {\n  const incidencia = $('Loop Followup').first().json;\n  const history = $input.item.json;\n  let events = [];\n  if (history?.data?.shipping_history?.events) {\n    events = history.data.shipping_history.events;\n  }\n  let formattedHistory = 'Sin eventos disponibles';\n  if (events.length > 0) {\n    formattedHistory = events.map(e => {\n      let date = e.event_date || e.item_event_date || '';\n      if (date) {\n        try {\n          const d = new Date(date);\n          d.setHours(d.getHours() + 1);\n          date = d.toISOString().replace('T', ' ').substring(0, 16);\n        } catch(x) {}\n      }\n      const code = e.code || e.event_code || 'N/A';\n      const desc = e.description || e.event_description || '';\n      const detail = e.detail?.External_event_text || e.detail?.item_event_text || '';\n      return `${date} - [${code}] ${desc} (${detail})`;\n    }).join('\\n');\n  }\n  return {\n    json: {\n      shipping_code: incidencia['NUMERO DE ENVIO'],\n      numero_pedido: incidencia['NUMERO DE PEDIDO'],\n      tienda: incidencia['TIENDA'],\n      credencial: incidencia['CREDENCIAL'],\n      incidencia_registrada: incidencia['INCIDENCIA'],\n      fecha_incidencia_original: incidencia['FECHA PROCESADO'],\n      formatted_history: formattedHistory\n    }\n  };\n} catch(error) {\n  throw new Error(`[Code FW JS3] ${error.message}`);\n}"
      },
      "id": "fb200a44-eb7e-4b07-9d43-d1d0c248260e",
      "name": "Code FW JS3",
