        "jsCode": "const raw = $input.item.json;\nconst aiText = raw.output[0].content[0].text;\nconst aiData = JSON.parse(aiText.replace(/```json|```/g, '').trim());\n\nconst incidencia = $('Loop Followup').first().json;\n\nreturn {\n  shipping_code: incidencia['NUMERO DE ENVIO'],\n  numero_pedido: incidencia['NUMERO DE PEDIDO'],\n  tienda: incidencia['TIENDA'],\n  credencial: incidencia['CREDENCIAL'],\n  incidencia_registrada: incidencia['INCIDENCIA'],\n  sigue_incidencia: aiData.sigue_incidencia === true,\n  estado_actual: aiData.estado_actual || '',\n  justification: aiData.justification || '',\n  email_body: aiData.email_body || ''\n};"
      },
